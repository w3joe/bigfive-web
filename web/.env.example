# Supabase — Project Settings → API (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key (optional for this app; server actions use the service role only).
# Needed if you add client-side Supabase or Realtime later.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: never expose in the browser. Used by Next.js server actions for DB writes/reads.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: override default table name (must match your migration).
# SUPABASE_RESULTS_TABLE=survey_results

# Existing app flags
# NEXT_PUBLIC_ENV=development
# NEXT_PUBLIC_ANALYTICS_ID=
